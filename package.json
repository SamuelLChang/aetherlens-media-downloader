{
  "name": "aetherlens-media-downloader",
  "private": true,
  "version": "0.1.3",
  "description": "Desktop media downloader built with Electron, React, and yt-dlp.",
  "keywords": [
    "electron",
    "react",
    "typescript",
    "media-downloader",
    "yt-dlp",
    "desktop-app",
    "video-downloader",
    "cross-platform"
  ],
  "license": "MIT",
  "author": "AetherLens",
  "scripts": {
    "dev": "vite",
    "prepare:aria2": "node scripts/bundle-aria2.mjs",
    "build": "tsc && vite build && electron-builder",
    "build:with-bundled-aria2": "npm run prepare:aria2 && npm run build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.556.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.4.0",
    "yt-dlp-exec": "^1.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "typescript": "5.5.4",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}